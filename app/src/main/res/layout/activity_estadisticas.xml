<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/btnLocal"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/btn_local"
            android:onClick="consultar"/>

        <Button android:id="@+id/btnExterno"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/btn_externo"
            android:onClick="consultar"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Por estado:" android:textStyle="bold" android:paddingTop="8dp"/>

    <ListView
        android:id="@+id/listEstado"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Por tipo de vehículo:" android:textStyle="bold" android:paddingTop="8dp"/>

    <ListView
        android:id="@+id/listTipo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
