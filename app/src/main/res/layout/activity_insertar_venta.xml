<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <EditText android:id="@+id/editIdVehiculo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_id_vehiculo" android:inputType="number"/>

        <EditText android:id="@+id/editIdImportador"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_id_importador" android:inputType="number"/>

        <EditText android:id="@+id/editFecha"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_fecha" android:inputType="text"/>

        <EditText android:id="@+id/editPrecio"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_precio" android:inputType="numberDecimal"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <Button android:id="@+id/btnLocal"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/btn_local"
                android:onClick="registrar"/>

            <Button android:id="@+id/btnExterno"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/btn_externo"
                android:onClick="registrar"/>

        </LinearLayout>

        <TextView android:id="@+id/txtResultado"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="8dp" android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>
