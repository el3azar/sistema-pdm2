<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <EditText android:id="@+id/editVin"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_vin" android:inputType="text"/>

        <EditText android:id="@+id/editAnio"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_anio" android:inputType="number"/>

        <EditText android:id="@+id/editColor"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_color" android:inputType="text"/>

        <EditText android:id="@+id/editEstado"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_estado" android:inputType="text"/>

        <EditText android:id="@+id/editIdModelo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_id_modelo" android:inputType="number"/>

        <EditText android:id="@+id/editIdTipo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_id_tipo" android:inputType="number"/>

        <EditText android:id="@+id/editIdSeccion"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_id_seccion" android:inputType="number"/>

        <EditText android:id="@+id/editIdImportacion"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_id_importacion" android:inputType="number"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <Button android:id="@+id/btnLocal"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/btn_local"
                android:onClick="registrar"/>

            <Button android:id="@+id/btnExterno"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/btn_externo"
                android:onClick="registrar"/>

        </LinearLayout>

        <TextView android:id="@+id/txtResultado"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="8dp" android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>
